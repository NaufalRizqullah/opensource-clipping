# ==============================================================================
# OpenSource Clipping — Environment Variables
# ==============================================================================
# Copy this file to `.env` and fill in your API keys:
#   cp .env.sample .env
# ==============================================================================

# [REQUIRED] Google Gemini API Key
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# [OPTIONAL] Pexels API Key — needed for B-roll stock footage
# Get yours at: https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key-here

# [OPTIONAL] HuggingFace Token — needed for split-screen mode (Pyannote speaker diarization)
# Get yours at: https://huggingface.co/settings/tokens
# You must also accept the model agreement: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=your-hf-token-here
